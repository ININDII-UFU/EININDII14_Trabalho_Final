  <types>
    <dataTypes/>
    <pous>
      <pou name="PID_NIVEL" pouType="functionBlock">
        <interface>
          <inputVars>
            <variable name="ENABLE"><type><BOOL/></type></variable>
            <variable name="PV_RAW"><type><UINT/></type></variable>
            <variable name="SP_PCT"><type><REAL/></type></variable>
            <variable name="KP"><type><REAL/></type></variable>
            <variable name="KI"><type><REAL/></type></variable>
            <variable name="KD"><type><REAL/></type></variable>
            <variable name="TS"><type><REAL/></type></variable>
            <variable name="OUT_MIN_PCT"><type><REAL/></type></variable>
            <variable name="OUT_MAX_PCT"><type><REAL/></type></variable>
          </inputVars>
          <outputVars>
            <variable name="OUT_RAW"><type><UINT/></type></variable>
            <variable name="PV_PCT"><type><REAL/></type></variable>
            <variable name="ERRO_PCT"><type><REAL/></type></variable>
            <variable name="OUT_PCT"><type><REAL/></type></variable>
            <variable name="SENSOR_FAULT"><type><BOOL/></type></variable>
            <variable name="SATURATED"><type><BOOL/></type></variable>
          </outputVars>
          <localVars>
            <variable name="integral"><type><REAL/></type></variable>
            <variable name="prevError"><type><REAL/></type></variable>
            <variable name="derivative"><type><REAL/></type></variable>
            <variable name="unsat"><type><REAL/></type></variable>
            <variable name="limited"><type><REAL/></type></variable>
          </localVars>
        </interface>
        <body><ST><xhtml:p><![CDATA[SENSOR_FAULT := PV_RAW = UINT#65535;

IF (NOT ENABLE) OR SENSOR_FAULT THEN
    OUT_RAW := UINT#0;
    OUT_PCT := 0.0;
    ERRO_PCT := 0.0;
    SATURATED := FALSE;
    integral := 0.0;
    prevError := 0.0;
ELSE
    PV_PCT := UINT_TO_REAL(PV_RAW) / 100.0;
    ERRO_PCT := SP_PCT - PV_PCT;

    IF TS > 0.0 THEN
        derivative := (ERRO_PCT - prevError) / TS;
    ELSE
        derivative := 0.0;
    END_IF;

    (* Integral candidata; aplicada somente quando não amplia a saturação. *)
    unsat := (KP * ERRO_PCT) + integral + (KD * derivative);

    IF unsat > OUT_MAX_PCT THEN
        limited := OUT_MAX_PCT;
    ELSIF unsat < OUT_MIN_PCT THEN
        limited := OUT_MIN_PCT;
    ELSE
        limited := unsat;
    END_IF;

    SATURATED := ABS(unsat - limited) > 0.0001;

    IF (NOT SATURATED)
       OR ((unsat > OUT_MAX_PCT) AND (ERRO_PCT < 0.0))
       OR ((unsat < OUT_MIN_PCT) AND (ERRO_PCT > 0.0)) THEN
        integral := integral + (KI * ERRO_PCT * TS);
    END_IF;

    (* Recalcula após atualizar a integral. *)
    unsat := (KP * ERRO_PCT) + integral + (KD * derivative);
    IF unsat > OUT_MAX_PCT THEN
        OUT_PCT := OUT_MAX_PCT;
    ELSIF unsat < OUT_MIN_PCT THEN
        OUT_PCT := OUT_MIN_PCT;
    ELSE
        OUT_PCT := unsat;
    END_IF;

    OUT_RAW := REAL_TO_UINT(OUT_PCT * 100.0);
    prevError := ERRO_PCT;
END_IF;]]></xhtml:p></ST></body>
      </pou>
      <pou name="MAIN" pouType="program">
        <interface>
          <localVars>
            <variable name="NivelRaw" address="%IW0"><type><UINT/></type></variable>
            <variable name="BombaCmdRaw" address="%QW0"><type><UINT/></type></variable>
            <variable name="ValvulaRaw" address="%IW1"><type><UINT/></type></variable>
            <variable name="VazaoEntrada" address="%IW2"><type><UINT/></type></variable>
            <variable name="VazaoSaida" address="%IW3"><type><UINT/></type></variable>
            <variable name="StatusPlanta" address="%IW4"><type><UINT/></type></variable>
            <variable name="ControleHabilitado"><type><BOOL/></type><initialValue><simpleValue value="true"/></initialValue></variable>
            <variable name="SetpointPct"><type><REAL/></type><initialValue><simpleValue value="50.0"/></initialValue></variable>
            <variable name="Kp"><type><REAL/></type><initialValue><simpleValue value="2.0"/></initialValue></variable>
            <variable name="Ki"><type><REAL/></type><initialValue><simpleValue value="0.08"/></initialValue></variable>
            <variable name="Kd"><type><REAL/></type><initialValue><simpleValue value="0.0"/></initialValue></variable>
            <variable name="Ts"><type><REAL/></type><initialValue><simpleValue value="0.1"/></initialValue></variable>
            <variable name="PID1"><type><derived name="PID_NIVEL"/></type></variable>
            <variable name="NivelPct"><type><REAL/></type></variable>
            <variable name="ErroPct"><type><REAL/></type></variable>
            <variable name="SaidaPct"><type><REAL/></type></variable>
            <variable name="FalhaSensor"><type><BOOL/></type></variable>
            <variable name="SaidaSaturada"><type><BOOL/></type></variable>
          </localVars>
        </interface>
        <body><ST><xhtml:p><![CDATA[PID1(
    ENABLE := ControleHabilitado,
    PV_RAW := NivelRaw,
    SP_PCT := SetpointPct,
    KP := Kp,
    KI := Ki,
    KD := Kd,
    TS := Ts,
    OUT_MIN_PCT := 0.0,
    OUT_MAX_PCT := 100.0
);

BombaCmdRaw := PID1.OUT_RAW;
NivelPct := PID1.PV_PCT;
ErroPct := PID1.ERRO_PCT;
SaidaPct := PID1.OUT_PCT;
FalhaSensor := PID1.SENSOR_FAULT;
SaidaSaturada := PID1.SATURATED;]]></xhtml:p></ST></body>
      </pou>
    </pous>
